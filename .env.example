# === App ===
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# === Security ===
JWT_SECRET=change-me-min-32-chars-random-string
JWT_ADMIN_SECRET=change-me-different-from-jwt-secret
API_KEY_SECRET=change-me-min-32-chars-random-string
MACHINE_ID_SALT=change-me-random-string
CREDENTIALS_ENCRYPT_KEY=change-me-32-chars-for-aes256-credentials

# === Database ===
DATABASE_URL=postgresql://zgate:zgate@localhost:5432/zgate

# === Redis ===
REDIS_URL=redis://localhost:6379

# === Email ===
EMAIL_FROM=ZGate <noreply@zgate.ziron.dev>
# Dev: Mailpit
SMTP_HOST=localhost
SMTP_PORT=1025
# Prod: Resend
RESEND_API_KEY=

# === Admin ===
ADMIN_EMAIL=admin@zgate.ziron.dev
ADMIN_PASSWORD=changeme-admin-password

# === OTP ===
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=3
OTP_SUSPEND_HOURS=1

# === Optional: Cloud Sync ===
NEXT_PUBLIC_CLOUD_URL=

# === Optional: Proxy ===
# HTTP_PROXY=
# HTTPS_PROXY=

# === RTK Engine ===
RTK_BINARY_PATH=./rtk/target/release/rtk

# === Debug ===
ENABLE_REQUEST_LOGS=false

# === Memory ===
MEMORY_ENABLED=true
MEMORY_EMBEDDING_MODEL=openai/text-embedding-3-small
MEMORY_TOP_K=5
MEMORY_EXTRACTION_MODEL=deepseek/deepseek-v4-flash
MEMORY_ENCRYPT_KEY=change-me-32-chars-for-aes256

# === WebSocket ===
WS_PORT=3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# === OAuth Provider Credentials ===
# CLIENT_ID: public identifier, boleh diketahui
# CLIENT_SECRET: sensitif, isi dari sumber terpercaya (jangan commit ke git)

# Claude (Anthropic) — no secret needed
OAUTH_CLAUDE_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
OAUTH_CLAUDE_TOKEN_URL=https://api.anthropic.com/v1/oauth/token

# Gemini / Gemini CLI — secret required
OAUTH_GEMINI_CLIENT_ID=681255809395-oo8ft2oprdrnp9e3aqf6av3hmdib135j.apps.googleusercontent.com
OAUTH_GEMINI_CLIENT_SECRET=
OAUTH_GEMINI_TOKEN_URL=https://oauth2.googleapis.com/token

# OpenAI Codex — no secret needed
OAUTH_CODEX_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
OAUTH_CODEX_TOKEN_URL=https://auth.openai.com/oauth/token

